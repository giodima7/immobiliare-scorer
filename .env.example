# Idealista API credentials
# Register at https://developers.idealista.com to get your key and secret
IDEALISTA_KEY=your_api_key_here
IDEALISTA_SECRET=your_api_secret_here

# Supabase — required for local dashboard tools (geo-enrich, rescore,
# data-quality, send-digest) when no rentals/sales JSON has been written
# locally yet. SUPABASE_URL is also baked into dashboard/index.html as a
# hardcoded fallback, but supabase_sync.py reads it from env.
#
# SUPABASE_SERVICE_KEY grants WRITE access (RLS-bypassing) — never commit
# this value, never embed it in HTML, never expose it to the browser.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...
