# Python
__pycache__/
*.pyc
*.pyo

# Sensitive config — SMTP password / Netlify token / API keys live here
email_config.json
netlify_config.json
.env

# Local-only runtime files
.digest_sent_date
scanner.log
scanner_idealista.log
sale_fetch.log
idealista_scanner.log
idealista_sale_fetch.log
scanner_status.json
seen_ids.backup.json

# User-configured scan preferences — edited via localhost:8000 dashboard.
# Kept local-only so git pull never overwrites the user's settings.
scan_prefs.json
sale_fetch_prefs.json

# Bulky raw export files in project root
listings_*.json
listings_*.csv
test_run_*.json
test_run_*.csv

# macOS
.DS_Store

# Virtual environments
venv/
.venv/

# Node (icon generation tooling)
node_modules/
package-lock.json
generate_icons.js
# package.json IS tracked — Cloudflare Pages uses it to skip pip install
# and to run `npm run build` → bash build.sh.

# Generated PWA icons (build from source elsewhere)
icon-192.png
icon-512.png

# Local POI cache (large, can be re-downloaded via dashboard Settings)
milan_pois.json

# OMI multi-city expansion
# OMI/ — full Italian KML dump (~7,900 files, 404 MB). Reference data
#       processed into omi_data/*.json by update_omi.py; never commit.
# omi_data/QIP_*.csv, omi_data/*.kml — raw Agenzia delle Entrate downloads
#       (large; processed into per-city JSON).
# The processed per-city JSON files (omi_data/*_zones.json /
# *_polygons.json) ARE tracked — they're the actual runtime input.
OMI/
omi_data/QIP_*.csv
omi_data/*.kml

# AI workspace
.claude/

# Keep state files tracked (updated by GitHub Actions daily scan).
# Listing data lives in Supabase now — never commit the JSON snapshots.
!enriched_cache.json
!seen_ids.json
rentals_latest.json
sales_latest.json
dashboard/rentals_latest.json
dashboard/sales_latest.json

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example
